@startuml RaiImageCD
' Release: 3.7.3

title RaiImage Core Class Diagram

skinparam backgroundColor white
skinparam shadowing false
skinparam DiagramFontName "Casual"
skinparam DiagramFontSize 36
skinparam ClassFontName "Casual"
skinparam ClassFontSize 36
skinparam ClassAttributeIconSize 10
skinparam ClassAttributeFontName Casual
skinparam ClassAttributeFontColor #053583
skinparam ClassAttributeFontWeight normal
skinparam ClassAttributeFontSize 12
skinparam ClassMethodFontName "Casual"
skinparam ClassMethodFontSize 12
skinparam ClassMethodFontWeight 500
skinparam ClassAttributeFontStyle normal
skinparam ClassBorderColor #0f766e
skinparam ClassBackgroundColor #ccfbf1
skinparam ClassFontColor #111827
skinparam EnumBorderColor #b45309
skinparam EnumBackgroundColor #fef3c7
skinparam EnumFontColor #7c2d12
skinparam NoteBackgroundColor #fff7d6
skinparam NoteBorderColor #d4b106
skinparam ArrowColor #9b2c2c
skinparam ArrowFontColor #374151
skinparam ArrowFontName "Casual"

hide empty members

package "RaiImage" {
	class "<size:18>ImageFile</size>" as ImageFile {
		+NoImageNumber : int
		+Image : System.Drawing.Image
		+Sku : string
		+NameExt : string
		+ImageNumber : int
		+TileTemplate : string
		+TileNumber : string
		+Color : ColorInfo
		+ShortName : string
		+FromFile(clone : bool) : System.Drawing.Image
		+EasyFileName(pic : string, renameFile : bool = false) : string
		+ExtendToFirstExistingFile(extensions : string, colorInfo : ColorInfo = null) : bool
	}

	class "<size:18>ImageTreeFile</size>" as ImageTreeFile {
		+Convention : PathConventionType
		+Topdir : string
		+Subdir : string
		+TopdirRoot : string
		+SubdirRoot : string
		+MoveToTree(fromDir : string, toDirRoot : string, filter : string, remove : string) : int
		+CopyTo(destDirs : string[]) : bool
		+ApplyPathConvention() : void
	}

	class "<size:18>ImageMagick</size>" as ImageMagick {
		+ImPath : string
		+MagickCommand : string
		+OptiPngCommand : string
		+JpegTranCommand : string
		+JpegTranOptions : string
		+Message : string
		+Convert(...) : int
		+Mogrify(...) : int
		+Composite(...) : int
		+Identify(...) : int
		+OptiPng(imgFileName : string) : int
		+JpegTran(imgFileName : string) : int
		+CreateTiles(...) : int
		+EmptyForm(imgFile : ImageFile, imageWidth : int, imageHeight : int, drawString : string) : bool
	}

	class "<size:18>ImageMagickCommand</size>" as ImageMagickCommand {
		+BuildArguments(subcommand : string, args : string = "") : string
		+RunSubcommand(subcommand : string, args : string = "") : RaiSystemResult
		+RunSubcommandAsync(subcommand : string, args : string = "") : Task<RaiSystemResult>
	}

	class "<size:18>ColorInfo</size>" as ColorInfo {
		+ColorNamesFile : string
		+Color : System.Drawing.Color
		+Count : int
		+Code : string
		+Name : string
		+Get(nameOrHexCode : string) : ColorInfo
	}

	class "<size:18>ImageTypes</size>" as ImageTypes {
		+Default : ImageTypes
	}

	class "<size:18>Pane</size>" as Pane
	class "<size:18>Panes</size>" as Panes
	class "<size:18>Src</size>" as Src
	class "<size:18>Tmp</size>" as Tmp
	class "<size:18>ImageUrl</size>" as ImageUrl
	class "<size:18>ItemTreePath</size>" as ItemTreePath
	interface "<size:18>IPathConvention</size>" as IPathConvention
	enum "<size:18>PathConventionType</size>" as PathConventionType << (E,#f59e0b) >>
}

package "OsLib" {
	class "RaiFile" as RaiFile <<external>>
	abstract class "CliCommand" as CliCommand <<external>>
	class "RaiSystemResult" as RaiSystemResult <<external>>
}

ImageFile --|> RaiFile
ImageTreeFile --|> ImageFile
ImageTreeFile ..|> IPathConvention

ImageFile --> ColorInfo : uses
ImageFile ..> ImageTreeFile : probes
ImageFile ..> ItemTreePath : path rules

ImageMagick ..> ImageFile : transforms
ImageMagick --> ImageMagickCommand : delegates CLI calls
ImageMagickCommand --|> CliCommand
ImageMagickCommand ..> RaiSystemResult : returns

ImageUrl ..> Src
ImageUrl ..> Tmp
Panes *-- Pane
IPathConvention ..> PathConventionType : uses

class "Legend<size:10>ⓈⒶⓅ</size>" as LegendSample {
	+{static} staticMethod() : void
	-{static} staticProperty : string
	==
	~<i>Note on class markers :</i>
	<size:10>Ⓢ</size>tatic
	<size:10>Ⓐ</size>bstract
	Ⓟartial
	--
	- privateField : string
	+ publicField : string
	# protectedField : string
	~ internalField : string
	--
	- privateMethod() : void
	+ publicMethod() : void
	# protectedMethod() : void
	~ internalMethod() : void
}

note top of ImageFile
	There is no single concrete
	`RaiImage` root class in code.
	This view centers the package
	on image-aware file types,
	derived path conventions,
	and ImageMagick integration.
end note

note right of ImageMagick
	Legacy image-processing facade retained.
	Process execution is routed through
	ImageMagickCommand and OsLib CLI helpers.
end note

@enduml
